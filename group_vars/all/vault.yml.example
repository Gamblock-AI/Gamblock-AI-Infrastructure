---
# Sensitive variables template. Run `make vault-init` to generate and encrypt
# the operational vault. Never commit a plaintext copy.

# ---- VPS root password ----
vault_vps_password: "replace-with-current-root-password"

# ---- GHCR / Docker registry ----
# Fine-grained/classic GitHub PAT with read:packages for private images.
vault_github_registry_pat: "replace-with-github-pat-read-packages"

# ---- PostgreSQL ----
vault_postgres_password: "change-this-strong-postgres-password"

# ---- Gamblock-AI Backend secrets ----
vault_gamblock_backend:
  jwt_access_secret: "generate-with-openssl-rand-hex-32"
  journal_encryption_key: "generate-with-openssl-rand-hex-32"
  smtp_host: ""
  smtp_port: 0
  smtp_username: ""
  smtp_password: ""
  smtp_from: ""
  whatsapp_api_key: ""
  whatsapp_phone_id: ""
  whatsapp_base_url: "https://graph.facebook.com/v18.0"

# ---- Cloudflare API ----
vault_cloudflare_api_token: ""
