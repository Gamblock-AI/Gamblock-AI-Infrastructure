services:
  {{ gamblock_ai_backend.name }}:
    image: {{ gamblock_ai_backend.image }}
    container_name: {{ gamblock_ai_backend.name }}
    restart: unless-stopped
    env_file: .env
    volumes:
      - {{ gamblock_ai_backend.name }}_artifacts:/app/var/artifacts
      - {{ gamblock_ai_backend.name }}_exports:/app/var/exports
      - {{ gamblock_ai_backend.name }}_media:/app/var/media
    networks:
      {{ '# noqa' }}
{% for net in gamblock_ai_backend.networks %}
      - {{ net }}
{% endfor %}
    healthcheck:
      test: ["CMD", "wget", "-qO-", "--tries=1", "--spider", "http://localhost:{{ gamblock_ai_backend.port }}/healthz"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s

  migrate-up:
    image: {{ gamblock_ai_backend.image }}
    profiles: ["tools"]
    entrypoint: ["/app/migrate-up"]
    env_file: .env
    networks:
      - {{ postgres_network }}

  migrate-down:
    image: {{ gamblock_ai_backend.image }}
    profiles: ["tools"]
    entrypoint: ["/app/migrate-down"]
    env_file: .env
    networks:
      - {{ postgres_network }}

  seeder:
    image: {{ gamblock_ai_backend.image }}
    profiles: ["tools"]
    entrypoint: ["/app/seeder"]
    env_file: .env
    volumes:
      - {{ gamblock_ai_backend.name }}_media:/app/var/media
    networks:
      - {{ postgres_network }}

networks:
{% for net in gamblock_ai_backend.networks %}
  {{ net }}:
    external: true
{% endfor %}

volumes:
  {{ gamblock_ai_backend.name }}_artifacts:
  {{ gamblock_ai_backend.name }}_exports:
  {{ gamblock_ai_backend.name }}_media:
