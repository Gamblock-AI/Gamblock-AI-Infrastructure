APP_ENV=production
HTTP_ADDR=:8080
PUBLIC_WEB_BASE_URL=https://app.{{ primary_domain }}
NOTIFICATION_MODE=production

DATABASE_URL=postgres://{{ gamblock_db_username }}:{{ vault_gamblock_db_password }}@{{ postgres_container_name }}:{{ postgres_port }}/{{ gamblock_db_name }}?sslmode=disable

JWT_ACCESS_SECRET={{ vault_gamblock_backend.jwt_access_secret }}
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=720h

CORS_ALLOWED_ORIGINS=https://app.{{ primary_domain }}

ARTIFACT_STORAGE_PATH=/app/var/artifacts
EXPORT_STORAGE_PATH=/app/var/exports

JOURNAL_ENCRYPTION_KEY={{ vault_gamblock_backend.journal_encryption_key }}

WHATSAPP_API_KEY={{ vault_gamblock_backend.whatsapp_api_key }}
WHATSAPP_PHONE_ID={{ vault_gamblock_backend.whatsapp_phone_id }}
WHATSAPP_BASE_URL={{ vault_gamblock_backend.whatsapp_base_url }}
