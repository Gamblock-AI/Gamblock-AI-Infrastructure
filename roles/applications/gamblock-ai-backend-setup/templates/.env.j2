APP_ENV=production
HTTP_ADDR=:8080
PUBLIC_WEB_BASE_URL=https://{{ primary_domain }}
NOTIFICATION_MODE=production
ENABLE_DEV_LOGIN=false
ENABLE_DEMO_DATA=false

DATABASE_URL=postgres://{{ gamblock_db_username }}:{{ vault_postgres_password }}@{{ postgres_container_name }}:{{ postgres_port }}/{{ gamblock_db_name }}?sslmode=disable

JWT_ACCESS_SECRET={{ vault_gamblock_backend.jwt_access_secret }}
JWT_ACCESS_TTL=24h
JWT_REFRESH_TTL=720h

CORS_ALLOWED_ORIGINS=https://{{ primary_domain }}

GOOGLE_CLIENT_ID={{ google_web_client_id }}
GOOGLE_CLIENT_IDS={{ google_web_client_id }},{{ google_windows_client_id }}

ARTIFACT_STORAGE_PATH=/app/var/artifacts
EXPORT_STORAGE_PATH=/app/var/exports
MEDIA_STORAGE_PATH=/app/var/media/education
AVATAR_STORAGE_PATH=/app/var/media/avatars

JOURNAL_ENCRYPTION_KEY={{ vault_gamblock_backend.journal_encryption_key }}

WHATSAPP_API_KEY={{ vault_gamblock_backend.whatsapp_api_key }}
WHATSAPP_PHONE_ID={{ vault_gamblock_backend.whatsapp_phone_id }}
WHATSAPP_BASE_URL={{ vault_gamblock_backend.whatsapp_base_url }}

SMTP_HOST={{ vault_gamblock_backend.smtp_host }}
SMTP_PORT={{ vault_gamblock_backend.smtp_port }}
SMTP_USERNAME={{ vault_gamblock_backend.smtp_username }}
SMTP_PASSWORD={{ vault_gamblock_backend.smtp_password }}
SMTP_FROM={{ vault_gamblock_backend.smtp_from }}
